# BiomeOS Connection
BIOMEOS_URL=http://localhost:3000

# Mock Mode (for testing without BiomeOS)
# Set to "true" to use mock data instead of real BiomeOS connection
PETALTONGUE_MOCK_MODE=false

# Refresh Interval (milliseconds)
# How often to poll BiomeOS for updates
PETALTONGUE_REFRESH_INTERVAL=500

# Audio Settings
# Enable/disable audio sonification
PETALTONGUE_AUDIO_ENABLED=true

# Logging
# Options: trace, debug, info, warn, error
RUST_LOG=info

# Animation Settings
# Enable/disable flow animations
PETALTONGUE_ANIMATION_ENABLED=true

# Performance Tuning
# Maximum FPS for rendering (0 = unlimited)
PETALTONGUE_MAX_FPS=60

# Graph Layout
# Layout algorithm: force_directed, hierarchical, circular, radial
PETALTONGUE_LAYOUT=force_directed

# Capability Detection
# Set to false to skip hardware capability detection
PETALTONGUE_DETECT_CAPABILITIES=true
