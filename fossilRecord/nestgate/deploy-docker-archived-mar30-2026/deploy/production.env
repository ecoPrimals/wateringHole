# NestGate Production Environment Configuration
# This file contains production-ready settings for NestGate deployment

# =============================================================================
# CORE SERVICE CONFIGURATION
# =============================================================================

# API Configuration
NESTGATE_API_PORT=8080
NESTGATE_BIND_ADDRESS=0.0.0.0
NESTGATE_WORKERS=auto
NESTGATE_REQUEST_TIMEOUT_SECS=30
NESTGATE_MAX_REQUEST_BODY_SIZE=10485760

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Primary Storage Backend
NESTGATE_STORAGE_BACKEND=zfs
NESTGATE_STORAGE_ZFS_POOL=tank
NESTGATE_STORAGE_DATA_DIR=/var/lib/nestgate

# Storage Performance
NESTGATE_STORAGE_CACHE_SIZE=1073741824  # 1GB
NESTGATE_STORAGE_COMPRESSION=true
NESTGATE_STORAGE_DEDUPLICATION=true

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Zero-Cost Architecture Settings
NESTGATE_ZERO_COPY=true
NESTGATE_BUFFER_SIZE=65536
NESTGATE_THREAD_POOL_SIZE=auto
NESTGATE_ASYNC_RUNTIME=tokio

# Connection Pooling
NESTGATE_MAX_CONNECTIONS=1000
NESTGATE_CONNECTION_TIMEOUT_SECS=30
NESTGATE_POOL_SIZE=100

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# TLS Configuration
NESTGATE_TLS_ENABLED=true
NESTGATE_TLS_CERT_PATH=/etc/nestgate/certs/server.crt
NESTGATE_TLS_KEY_PATH=/etc/nestgate/certs/server.key
NESTGATE_TLS_CA_PATH=/etc/nestgate/certs/ca.crt

# Authentication
NESTGATE_AUTH_MODE=primal
NESTGATE_AUTH_TOKEN_EXPIRATION=3600
NESTGATE_AUTH_REFRESH_THRESHOLD=300

# Authorization
NESTGATE_RBAC_ENABLED=true
NESTGATE_RBAC_CONFIG_PATH=/etc/nestgate/rbac.yml

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Metrics
NESTGATE_METRICS_ENABLED=true
NESTGATE_METRICS_PORT=9090
NESTGATE_METRICS_ENDPOINT=/metrics

# Health Checks
NESTGATE_HEALTH_CHECK_ENABLED=true
NESTGATE_HEALTH_CHECK_INTERVAL=30
NESTGATE_HEALTH_CHECK_TIMEOUT=10

# Logging
NESTGATE_LOG_LEVEL=info
NESTGATE_LOG_FORMAT=json
NESTGATE_LOG_FILE=/var/log/nestgate/nestgate.log
NESTGATE_LOG_ROTATION=daily
NESTGATE_LOG_MAX_SIZE=100MB

# Tracing
NESTGATE_TRACING_ENABLED=true
NESTGATE_TRACING_ENDPOINT=http://jaeger:14268/api/traces
NESTGATE_TRACING_SAMPLE_RATE=0.1

# =============================================================================
# ECOSYSTEM INTEGRATION
# =============================================================================

# Service Discovery
NESTGATE_ECOSYSTEM_DISCOVERY=true
NESTGATE_DISCOVERY_INTERVAL=60
NESTGATE_DISCOVERY_TIMEOUT=10

# Ecosystem Service Endpoints
ORCHESTRATION_DISCOVERY_ENDPOINT=http://discovery:8081/capabilities/orchestration
SECURITY_DISCOVERY_ENDPOINT=http://discovery:8082/capabilities/security
AI_DISCOVERY_ENDPOINT=http://discovery:8083/capabilities/artificial_intelligence
COMPUTE_DISCOVERY_ENDPOINT=http://discovery:8084/capabilities/compute
MANAGEMENT_DISCOVERY_ENDPOINT=http://discovery:8085/capabilities/management

# Integration Configuration
NESTGATE_INTEGRATION_TIMEOUT=30
NESTGATE_INTEGRATION_RETRY_ATTEMPTS=3
NESTGATE_INTEGRATION_RETRY_DELAY=5

# =============================================================================
# DEVELOPMENT & DEBUGGING (Production: Disabled)
# =============================================================================

# Development Features (Disabled in Production)
NESTGATE_DEV_MODE=false
NESTGATE_DEBUG_LOGGING=false
NESTGATE_MOCK_SERVICES=false
NESTGATE_UNSAFE_OPERATIONS=false

# Profiling (Disabled in Production)
NESTGATE_PROFILING_ENABLED=false
NESTGATE_MEMORY_PROFILING=false
NESTGATE_CPU_PROFILING=false

# =============================================================================
# RESOURCE LIMITS
# =============================================================================

# Memory Limits
NESTGATE_MAX_MEMORY_MB=4096
NESTGATE_CACHE_MAX_MEMORY_MB=1024
NESTGATE_BUFFER_MAX_MEMORY_MB=512

# CPU Limits
NESTGATE_MAX_CPU_CORES=4
NESTGATE_CPU_AFFINITY=auto

# File Descriptor Limits
NESTGATE_MAX_OPEN_FILES=65536
NESTGATE_MAX_CONNECTIONS_PER_IP=100

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Backup Configuration
NESTGATE_BACKUP_ENABLED=true
NESTGATE_BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
NESTGATE_BACKUP_RETENTION_DAYS=30
NESTGATE_BACKUP_COMPRESSION=true
NESTGATE_BACKUP_ENCRYPTION=true

# Recovery Configuration
NESTGATE_RECOVERY_ENABLED=true
NESTGATE_RECOVERY_POINT_INTERVAL=3600  # 1 hour
NESTGATE_RECOVERY_MAX_POINTS=168       # 1 week

# =============================================================================
# DEPLOYMENT METADATA
# =============================================================================

# Deployment Information
NESTGATE_VERSION=2.0.0
NESTGATE_BUILD_DATE=2025-09-10
NESTGATE_DEPLOYMENT_ENV=production
NESTGATE_DEPLOYMENT_REGION=us-west-2
NESTGATE_DEPLOYMENT_ZONE=us-west-2a

# Contact Information
NESTGATE_ADMIN_EMAIL=admin@ecoprimals.com
NESTGATE_SUPPORT_URL=https://support.ecoprimals.com
NESTGATE_DOCUMENTATION_URL=https://docs.ecoprimals.com/nestgate 