# NestGate Staging Environment Configuration - Universal Adapter Edition
# This file contains staging-ready settings for NestGate deployment with universal adapter
# Date: September 12, 2025
# Status: Universal Adapter Migration - Staging Validation

# =============================================================================
# CORE SERVICE CONFIGURATION
# =============================================================================

# API Configuration
NESTGATE_API_PORT=8080
NESTGATE_BIND_ADDRESS=0.0.0.0
NESTGATE_WORKERS=auto
NESTGATE_REQUEST_TIMEOUT_SECS=30
NESTGATE_MAX_REQUEST_BODY_SIZE=10485760

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Primary Storage Backend
NESTGATE_STORAGE_BACKEND=zfs
NESTGATE_STORAGE_ZFS_POOL=tank-staging
NESTGATE_STORAGE_DATA_DIR=/var/lib/nestgate-staging

# Storage Performance
NESTGATE_STORAGE_CACHE_SIZE=536870912  # 512MB for staging
NESTGATE_STORAGE_COMPRESSION=true
NESTGATE_STORAGE_DEDUPLICATION=true

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Zero-Cost Architecture Settings
NESTGATE_ZERO_COPY=true
NESTGATE_BUFFER_SIZE=65536
NESTGATE_THREAD_POOL_SIZE=auto
NESTGATE_ASYNC_RUNTIME=tokio

# Connection Pooling
NESTGATE_MAX_CONNECTIONS=500  # Reduced for staging
NESTGATE_CONNECTION_TIMEOUT_SECS=30
NESTGATE_POOL_SIZE=50

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# TLS Configuration
NESTGATE_TLS_ENABLED=true
NESTGATE_TLS_CERT_PATH=/etc/nestgate/certs/staging-server.crt
NESTGATE_TLS_KEY_PATH=/etc/nestgate/certs/staging-server.key
NESTGATE_TLS_CA_PATH=/etc/nestgate/certs/staging-ca.crt

# Authentication
NESTGATE_AUTH_MODE=primal
NESTGATE_AUTH_TOKEN_EXPIRATION=3600
NESTGATE_AUTH_REFRESH_THRESHOLD=300

# Authorization
NESTGATE_RBAC_ENABLED=true
NESTGATE_RBAC_CONFIG_PATH=/etc/nestgate/staging-rbac.yml

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Metrics
NESTGATE_METRICS_ENABLED=true
NESTGATE_METRICS_PORT=9090
NESTGATE_METRICS_ENDPOINT=/metrics

# Health Checks
NESTGATE_HEALTH_CHECK_ENABLED=true
NESTGATE_HEALTH_CHECK_INTERVAL=30
NESTGATE_HEALTH_CHECK_TIMEOUT=10

# Logging
NESTGATE_LOG_LEVEL=debug  # More verbose for staging
NESTGATE_LOG_FORMAT=json
NESTGATE_LOG_FILE=/var/log/nestgate/nestgate-staging.log
NESTGATE_LOG_ROTATION=daily
NESTGATE_LOG_MAX_SIZE=100MB

# Tracing
NESTGATE_TRACING_ENABLED=true
NESTGATE_TRACING_ENDPOINT=http://jaeger-staging:14268/api/traces
NESTGATE_TRACING_SAMPLE_RATE=0.5  # Higher sampling for staging

# =============================================================================
# ✅ UNIVERSAL ADAPTER CONFIGURATION - MODERN CAPABILITY-BASED ARCHITECTURE
# =============================================================================

# Universal Adapter Core Settings
UNIVERSAL_ADAPTER_ENABLED=true
UNIVERSAL_ADAPTER_DISCOVERY_METHOD=hybrid  # auto, network_scan, environment, service_registry, hybrid
UNIVERSAL_ADAPTER_MAX_CONCURRENT_DISCOVERIES=10
UNIVERSAL_ADAPTER_DISCOVERY_TIMEOUT_SECS=30
UNIVERSAL_ADAPTER_CAPABILITY_CACHE_TTL_SECS=300

# Service Discovery Configuration
CAPABILITY_DISCOVERY_ENABLED=true
CAPABILITY_DISCOVERY_INTERVAL_SECS=60
CAPABILITY_DISCOVERY_TIMEOUT_SECS=10
CAPABILITY_DISCOVERY_HEALTH_CHECK_INTERVAL_SECS=30

# Capability-Based Service Endpoints (Dynamic Discovery Fallback)
# These are used as fallbacks when dynamic discovery is unavailable
ORCHESTRATION_DISCOVERY_ENDPOINT=http://orchestration-staging:8081/capabilities
SECURITY_DISCOVERY_ENDPOINT=http://security-staging:8082/capabilities  
AI_DISCOVERY_ENDPOINT=http://ai-staging:8083/capabilities
COMPUTE_DISCOVERY_ENDPOINT=http://compute-staging:8084/capabilities
MANAGEMENT_DISCOVERY_ENDPOINT=http://management-staging:8085/capabilities

# Performance Requirements for Capabilities
SECURITY_CAPABILITY_MAX_LATENCY_MS=2000
SECURITY_CAPABILITY_MIN_RELIABILITY_PERCENT=99.5

ORCHESTRATION_CAPABILITY_MAX_LATENCY_MS=3000
ORCHESTRATION_CAPABILITY_MIN_RELIABILITY_PERCENT=98.0

AI_CAPABILITY_MAX_LATENCY_MS=30000
AI_CAPABILITY_MIN_RELIABILITY_PERCENT=95.0

COMPUTE_CAPABILITY_MAX_LATENCY_MS=10000
COMPUTE_CAPABILITY_MIN_RELIABILITY_PERCENT=95.0

# Fallback Strategy Configuration
CAPABILITY_FALLBACK_ENABLED=true
CAPABILITY_LOCAL_FALLBACK_ENABLED=true
CAPABILITY_DEGRADED_MODE_ENABLED=true
CAPABILITY_RETRY_ATTEMPTS=3
CAPABILITY_RETRY_BACKOFF_MS=1000

# =============================================================================
# LEGACY COMPATIBILITY (DEPRECATED - STAGING TRANSITION SUPPORT)
# =============================================================================

# DEPRECATED: Legacy primal-specific endpoints (maintained for backward compatibility)
# These will be phased out during staging validation
# Use ORCHESTRATION_DISCOVERY_ENDPOINT instead of NESTGATE_SONGBIRD_ENDPOINT
# Use SECURITY_DISCOVERY_ENDPOINT instead of NESTGATE_BEARDOG_ENDPOINT
# Use AI_DISCOVERY_ENDPOINT instead of NESTGATE_SQUIRREL_ENDPOINT
# Use COMPUTE_DISCOVERY_ENDPOINT instead of NESTGATE_TOADSTOOL_ENDPOINT
# Use MANAGEMENT_DISCOVERY_ENDPOINT instead of NESTGATE_BIOMEOS_ENDPOINT

# Legacy Integration Configuration (DEPRECATED)
NESTGATE_INTEGRATION_TIMEOUT=30
NESTGATE_INTEGRATION_RETRY_ATTEMPTS=3
NESTGATE_INTEGRATION_RETRY_DELAY=5

# =============================================================================
# RPC ROUTING CONFIGURATION - UNIVERSAL ADAPTER
# =============================================================================

# Universal RPC Router Settings
UNIVERSAL_RPC_ROUTER_ENABLED=true
RPC_CONNECTION_TYPE_OPTIMIZATION=true

# Connection Type Preferences by Capability
SECURITY_RPC_CONNECTION_TYPE=tarpc        # High-performance binary for security
ORCHESTRATION_RPC_CONNECTION_TYPE=json    # Standard JSON RPC for orchestration
AI_RPC_CONNECTION_TYPE=json               # JSON RPC with extended timeouts
COMPUTE_RPC_CONNECTION_TYPE=tarpc         # High-performance for compute workloads
MANAGEMENT_RPC_CONNECTION_TYPE=websocket  # Real-time for management interfaces

# Connection Pool Configuration
RPC_CONNECTION_POOL_SIZE=25
RPC_CONNECTION_TIMEOUT_SECS=30
RPC_MAX_CONCURRENT_REQUESTS=100

# =============================================================================
# DEVELOPMENT & DEBUGGING (Staging: Enhanced)
# =============================================================================

# Development Features (Enhanced for staging validation)
NESTGATE_DEV_MODE=false
NESTGATE_DEBUG_LOGGING=true  # Enabled for staging debugging
NESTGATE_MOCK_SERVICES=false
NESTGATE_UNSAFE_OPERATIONS=false

# Universal Adapter Debugging
UNIVERSAL_ADAPTER_DEBUG_LOGGING=true
CAPABILITY_DISCOVERY_DEBUG=true
RPC_ROUTER_DEBUG_LOGGING=true

# Profiling (Enabled for staging performance analysis)
NESTGATE_PROFILING_ENABLED=true
NESTGATE_MEMORY_PROFILING=true
NESTGATE_CPU_PROFILING=true

# =============================================================================
# RESOURCE LIMITS (Staging: Reduced)
# =============================================================================

# Memory Limits
NESTGATE_MAX_MEMORY_MB=2048  # Reduced for staging
NESTGATE_CACHE_MAX_MEMORY_MB=512
NESTGATE_BUFFER_MAX_MEMORY_MB=256

# CPU Limits
NESTGATE_MAX_CPU_CORES=2  # Reduced for staging
NESTGATE_CPU_AFFINITY=auto

# File Descriptor Limits
NESTGATE_MAX_OPEN_FILES=32768
NESTGATE_MAX_CONNECTIONS_PER_IP=50

# =============================================================================
# BACKUP & RECOVERY (Staging: Simplified)
# =============================================================================

# Backup Configuration
NESTGATE_BACKUP_ENABLED=true
NESTGATE_BACKUP_SCHEDULE="0 4 * * *"  # Daily at 4 AM
NESTGATE_BACKUP_RETENTION_DAYS=7  # Reduced for staging
NESTGATE_BACKUP_COMPRESSION=true
NESTGATE_BACKUP_ENCRYPTION=false  # Simplified for staging

# Recovery Configuration
NESTGATE_RECOVERY_ENABLED=true
NESTGATE_RECOVERY_POINT_INTERVAL=7200  # 2 hours
NESTGATE_RECOVERY_MAX_POINTS=84        # 1 week

# =============================================================================
# STAGING DEPLOYMENT METADATA
# =============================================================================

# Deployment Information
NESTGATE_VERSION=2.0.0-universal-adapter
NESTGATE_BUILD_DATE=2025-09-12
NESTGATE_DEPLOYMENT_ENV=staging
NESTGATE_DEPLOYMENT_REGION=us-west-2
NESTGATE_DEPLOYMENT_ZONE=us-west-2a

# Universal Adapter Metadata
UNIVERSAL_ADAPTER_VERSION=1.0.0
UNIVERSAL_ADAPTER_BUILD_DATE=2025-09-12
PRIMAL_SOVEREIGNTY_MODE=enabled

# Contact Information
NESTGATE_ADMIN_EMAIL=staging-admin@ecoprimals.com
NESTGATE_SUPPORT_URL=https://staging-support.ecoprimals.com
NESTGATE_DOCUMENTATION_URL=https://docs.ecoprimals.com/nestgate/universal-adapter

# =============================================================================
# STAGING VALIDATION CONFIGURATION
# =============================================================================

# Universal Adapter Validation Settings
STAGING_VALIDATION_MODE=true
CAPABILITY_DISCOVERY_VALIDATION=true
RPC_ROUTING_VALIDATION=true
PERFORMANCE_BENCHMARKING=true

# Validation Metrics Collection
VALIDATION_METRICS_COLLECTION=true
CAPABILITY_DISCOVERY_LATENCY_TRACKING=true
RPC_PERFORMANCE_MONITORING=true
FALLBACK_STRATEGY_TESTING=true

# Test Environment Integration
INTEGRATION_TEST_MODE=enabled
MOCK_CAPABILITY_PROVIDERS=available
SYNTHETIC_LOAD_TESTING=enabled

# =============================================================================
# MONITORING ENHANCEMENTS FOR UNIVERSAL ADAPTER
# =============================================================================

# Universal Adapter Metrics
UNIVERSAL_ADAPTER_METRICS_ENABLED=true
CAPABILITY_DISCOVERY_METRICS=true
RPC_ROUTING_METRICS=true
PERFORMANCE_TIER_METRICS=true

# Alerting Configuration
CAPABILITY_UNAVAILABILITY_ALERTS=true
DISCOVERY_LATENCY_ALERTS=true
RPC_PERFORMANCE_ALERTS=true
FALLBACK_ACTIVATION_ALERTS=true

# Dashboard Configuration
UNIVERSAL_ADAPTER_DASHBOARD_ENABLED=true
CAPABILITY_HEALTH_DASHBOARD=true
PERFORMANCE_ANALYTICS_DASHBOARD=true
REAL_TIME_MONITORING_DASHBOARD=true 