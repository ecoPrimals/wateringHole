# NestGate Production Environment Configuration
# Generated: December 2, 2025

# Environment
NESTGATE_ENV=production
NESTGATE_HOST=0.0.0.0
NESTGATE_PORT=8080
NESTGATE_LOG_LEVEL=warn

# API Configuration
NESTGATE_API_HOST=0.0.0.0
NESTGATE_API_PORT=8080

# Monitoring
NESTGATE_METRICS_PORT=9090
NESTGATE_HEALTH_PORT=8082

# TLS/HTTPS (REQUIRED for production)
NESTGATE_TLS_ENABLED=true
NESTGATE_TLS_CERT_PATH=/etc/nestgate/certs/server.crt
NESTGATE_TLS_KEY_PATH=/etc/nestgate/certs/server.key

# Service Discovery (Configure your production services)
NESTGATE_CAPABILITY_ORCHESTRATION=https://orchestration.prod:8080
NESTGATE_CAPABILITY_SECURITY=https://security.prod:9000
NESTGATE_CAPABILITY_AI=https://ai.prod:7000
NESTGATE_CAPABILITY_COMPUTE=https://compute.prod:6000
NESTGATE_CAPABILITY_STORAGE=https://storage.prod:5000

# Database (REQUIRED for production)
NESTGATE_DATABASE_URL=postgresql://prod-db:5432/nestgate

# Redis (REQUIRED for production)
NESTGATE_REDIS_URL=redis://prod-redis:6379

# Security
NESTGATE_API_KEY_REQUIRED=true
NESTGATE_API_KEY=changeme_use_secure_key_here

# Rate Limiting
NESTGATE_RATE_LIMIT_ENABLED=true
NESTGATE_RATE_LIMIT_REQUESTS_PER_SECOND=100
