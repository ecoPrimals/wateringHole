# NestGate Staging Environment Configuration
# Generated: December 2, 2025

# Environment
NESTGATE_ENV=staging
NESTGATE_HOST=0.0.0.0
NESTGATE_PORT=8080
NESTGATE_LOG_LEVEL=info

# API Configuration
NESTGATE_API_HOST=0.0.0.0
NESTGATE_API_PORT=8080

# Monitoring
NESTGATE_METRICS_PORT=9090
NESTGATE_HEALTH_PORT=8082

# Service Discovery (Optional - uncomment to enable)
# NESTGATE_CAPABILITY_ORCHESTRATION=http://orchestration:8080
# NESTGATE_CAPABILITY_SECURITY=http://security:9000
# NESTGATE_CAPABILITY_AI=http://ai:7000
# NESTGATE_CAPABILITY_COMPUTE=http://compute:6000
# NESTGATE_CAPABILITY_STORAGE=http://storage:5000

# Database (Optional - uncomment to enable)
# NESTGATE_DATABASE_URL=postgresql://localhost:5432/nestgate_staging

# Redis (Optional - uncomment to enable)
# NESTGATE_REDIS_URL=redis://localhost:6379

# Security (Optional)
# NESTGATE_API_KEY_REQUIRED=false
# NESTGATE_TLS_ENABLED=false
