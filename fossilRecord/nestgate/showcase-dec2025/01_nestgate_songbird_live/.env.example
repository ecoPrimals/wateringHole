# NestGate Multi-Node Configuration
# Copy this to .env and configure as needed

# JWT Secret (REQUIRED)
# Generate with: openssl rand -base64 48
NESTGATE_JWT_SECRET=your-secure-secret-here

# Node Configuration
NESTGATE_PORT_1=9005
NESTGATE_PORT_2=9006
NESTGATE_PORT_3=9007

# Binary Location
NESTGATE_BIN=/path/to/ecoPrimals/nestgate/target/release/nestgate

# Songbird Integration (future)
SONGBIRD_URL=http://localhost:8080
SONGBIRD_ENABLED=false
